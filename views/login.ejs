<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login - AgentX.Market</title>
  <link rel="stylesheet" href="/css/style.css">
  <style>
    body {
      background-color: #0a0a1a;
      color: #e0e0ff;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }
    .navbar {
      background-color: #1a1a2e;
      padding: 1rem 2rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .logo {
      font-size: 1.5rem;
      font-weight: bold;
      color: #e0e0ff;
      text-decoration: none;
    }
    .nav-links {
      display: flex;
      list-style: none;
      gap: 1.5rem;
    }
    .nav-links a {
      color: #e0e0ff;
      text-decoration: none;
      transition: color 0.2s;
    }
    .nav-links a:hover {
      color: #ffffff;
    }
    .nav-cta {
      margin-left: auto;
    }
    .btn {
      padding: 0.5rem 1rem;
      border-radius: 4px;
      text-decoration: none;
      font-weight: 500;
      transition: all 0.2s;
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
    }
    .btn-primary {
      background-color: #2a2a4a;
      color: #e0e0ff;
      border: 1px solid #2a2a4a;
    }
    .btn-primary:hover {
      background-color: #3a3a5a;
      border-color: #3a3a5a;
    }
    .btn-secondary {
      background-color: #ffffff;
      color: #0a0a1a;
      border: 1px solid #ffffff;
    }
    .btn-secondary:hover {
      background-color: #f0f0f0;
      border-color: #f0f0f0;
    }
    .main-content {
      flex: 1;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      padding: 2rem;
    }
    .login-card {
      background-color: #1a1a2e;
      border: 1px solid #2a2a4a;
      border-radius: 8px;
      padding: 2rem;
      width: 100%;
      max-width: 400px;
      text-align: center;
    }
    .login-card h1 {
      margin-top: 0;
      margin-bottom: 2rem;
      color: #e0e0ff;
    }
    .login-card .btn {
      width: 100%;
      justify-content: center;
      margin-bottom: 1rem;
    }
    .login-card .terms {
      font-size: 0.8rem;
      color: #8888aa;
      margin-top: 1.5rem;
    }
    .footer {
      background-color: #1a1a2e;
      padding: 1rem 2rem;
      text-align: center;
      color: #8888aa;
      font-size: 0.9rem;
    }
    .footer a {
      color: #8888aa;
      text-decoration: none;
      margin: 0 0.5rem;
    }
    .footer a:hover {
      color: #e0e0ff;
    }
  </style>
</head>
<body>
  <nav class="navbar">
    <a href="/" class="logo">AgentX.Market</a>
    <ul class="nav-links">
      <li><a href="/features">Features</a></li>
      <li><a href="/pricing">Pricing</a></li>
      <li><a href="/browse">Browse</a></li>
      <li><a href="/about">About</a></li>
      <li><a href="/contact">Contact</a></li>
      <li class="nav-cta">
        <a href="/pricing" class="btn btn-primary">Get Started</a>
      </li>
    </ul>
  </nav>

  <main class="main-content">
    <div class="login-card">
      <h1>Sign in to AgentX</h1>
      <a href="/auth/github" class="btn btn-primary">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
        </svg>
        Sign in with GitHub
      </a>
      <a href="/auth/google" class="btn btn-secondary">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
          <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
          <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.665-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
          <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
        </svg>
        Sign in with Google
      </a>
      <p class="terms">By signing in, you agree to our Terms of Service</p>
    </div>
  </main>

  <footer class="footer">
    <p>
      © 2026 AgentX.Market. All rights reserved. |
      <a href="/privacy">Privacy Policy</a> |
      <a href="/terms">Terms of Service</a> |
      <a href="/contact">Contact</a>
    </p>
  </footer>
</body>
</html>