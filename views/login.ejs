<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login - AgentX.Market</title>
  <link rel="stylesheet" href="/css/style.css">
  <style>
    body {
      background-color: #0a0a1a;
      color: #e0e0ff;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }
    .navbar {
      background-color: #1a1a2e;
      padding: 1rem 2rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .logo {
      font-size: 1.5rem;
      font-weight: bold;
      color: #e0e0ff;
      text-decoration: none;
    }
    .nav-links {
      display: flex;
      list-style: none;
      gap: 1.5rem;
    }
    .nav-links a {
      color: #e0e0ff;
      text-decoration: none;
      transition: color 0.2s;
    }
    .nav-links a:hover {
      color: #ffffff;
    }
    .nav-cta {
      margin-left: auto;
    }
    .btn {
      padding: 0.5rem 1rem;
      border-radius: 4px;
      text-decoration: none;
      font-weight: 500;
      transition: all 0.2s;
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
    }
    .btn-primary {
      background-color: #2a2a4a;
      color: #e0e0ff;
      border: 1px solid #2a2a4a;
    }
    .btn-primary:hover {
      background-color: #3a3a5a;
      border-color: #3a3a5a;
    }
    .btn-secondary {
      background-color: #ffffff;
      color: #0a0a1a;
      border: 1px solid #ffffff;
    }
    .btn-secondary:hover {
      background-color: #f0f0f0;
      border-color: #f0f0f0;
    }
    .main-content {
      flex: 1;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      padding: 2rem;
    }
    .login-card {
      background-color: #1a1a2e;
      border: 1px solid #2a2a4a;
      border-radius: 8px;
      padding: 2rem;
      width: 100%;
      max-width: 400px;
      text-align: center;
    }
    .login-card h1 {
      margin-top: 0;
      margin-bottom: 2rem;
      color: #e0e0ff;
    }
    .login-card .btn {
      width: 100%;
      justify-content: center;
      margin-bottom: 1rem;
    }
    .login-card .terms {
      font-size: 0.8rem;
      color: #8888aa;
      margin-top: 1.5rem;
    }
    .footer {
      background-color: #1a1a2e;
      padding: 1rem 2rem;
      text-align: center;
      color: #8888aa;
      font-size: 0.9rem;
    }
    .footer a {
      color: #8888aa;
      text-decoration: none;
      margin: 0 0.5rem;
    }
    .footer a:hover {
      color: #e0e0ff;
    }
    .what-you-get {
      text-align: center;
      padding: 2rem;
      max-width: 800px;
      margin: 0 auto;
    }
    .what-you-get h2 {
      color: #e0e0ff;
      margin-bottom: 1.5rem;
      font-size: 1.5rem;
    }
    .features-grid {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 1rem;
      margin-bottom: 1.5rem;
    }
    .feature-item {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      background-color: #1a1a2e;
      border: 1px solid #2a2a4a;
      border-radius: 6px;
      padding: 0.75rem 1rem;
      color: #e0e0ff;
      font-size: 0.95rem;
    }
    .feature-item svg {
      color: #4a9eff;
    }
    .signup-note {
      color: #8888aa;
      font-size: 0.9rem;
      margin-bottom: 2rem;
    }
    .dashboard-preview {
      margin-top: 2rem;
    }
    .dashboard-mockup {
      background: linear-gradient(135deg, #1a1a2e 0%, #0f0f1f 100%);
      border: 1px solid #2a2a4a;
      border-radius: 8px;
      overflow: hidden;
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
    }
    .mockup-header {
      background-color: #1a1a2e;
      padding: 0.75rem 1rem;
      border-bottom: 1px solid #2a2a4a;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .mockup-title {
      color: #8888aa;
      font-size: 0.85rem;
      font-weight: 500;
    }
    .mockup-controls {
      display: flex;
      gap: 0.5rem;
    }
    .mockup-dot {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      background-color: #3a3a5a;
    }
    .mockup-body {
      display: flex;
      min-height: 180px;
    }
    .mockup-sidebar {
      width: 60px;
      background-color: #0f0f1f;
      padding: 1rem 0.5rem;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }
    .mockup-menu-item {
      width: 36px;
      height: 36px;
      background-color: #1a1a2e;
      border-radius: 6px;
    }
    .mockup-main {
      flex: 1;
      padding: 1rem;
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }
    .mockup-card {
      height: 60px;
      background: linear-gradient(90deg, #1a1a2e 0%, #0f0f1f 100%);
      border: 1px solid #2a2a4a;
      border-radius: 6px;
    }
    .mockup-chart {
      flex: 1;
      background: linear-gradient(180deg, #1a1a2e 0%, #0f0f1f 100%);
      border: 1px solid #2a2a4a;
      border-radius: 6px;
      position: relative;
      overflow: hidden;
    }
    .mockup-chart::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      height: 60%;
      background: linear-gradient(180deg, rgba(74, 158, 255, 0.1) 0%, transparent 100%);
    }
  </style>
</head>
<body>
  <nav class="navbar">
    <a href="/" class="logo">AgentX.Market</a>
    <ul class="nav-links">
      <li><a href="/features">Features</a></li>
      <li><a href="/pricing">Pricing</a></li>
      <li><a href="/browse">Browse</a></li>
      <li><a href="/about">About</a></li>
      <li><a href="/contact">Contact</a></li>
      <li class="nav-cta">
        <a href="/pricing" class="btn btn-primary">Get Started</a>
      </li>
    </ul>
  </nav>

  <main class="main-content">
    <div class="login-card">
      <h1>Sign in to AgentX</h1>
      <a href="/auth/github" class="btn btn-primary">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
        </svg>
        Sign in with GitHub
      </a>
      <a href="/auth/google" class="btn btn-secondary">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
          <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
          <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.665-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
          <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
        </svg>
        Sign in with Google
      </a>
      <p class="terms">By signing in, you agree to our Terms of Service</p>
    </div>

    <div class="what-you-get">
      <h2>What You Get</h2>
      <div class="features-grid">
        <div class="feature-item">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
          </svg>
          <span>Register agents</span>
        </div>
        <div class="feature-item">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
            <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
          </svg>
          <span>Get API keys</span>
        </div>
        <div class="feature-item">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="18" y1="20" x2="18" y2="10"/>
            <line x1="12" y1="20" x2="12" y2="4"/>
            <line x1="6" y1="20" x2="6" y2="14"/>
          </svg>
          <span>View health dashboards</span>
        </div>
        <div class="feature-item">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
            <polyline points="3.27 6.96 12 12.01 20.73 6.96"/>
            <line x1="12" y1="22.08" x2="12" y2="12"/>
          </svg>
          <span>Manage listings</span>
        </div>
        <div class="feature-item">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21.21 15.89A10 10 0 1 1 8 2.83"/>
            <path d="M22 12A10 10 0 0 0 12 2v10z"/>
          </svg>
          <span>Track analytics</span>
        </div>
      </div>
      <p class="signup-note">Sign in or create your free account — we only request your public profile.</p>
      <div class="dashboard-preview">
        <div class="dashboard-mockup">
          <div class="mockup-header">
            <div class="mockup-title">Dashboard</div>
            <div class="mockup-controls">
              <div class="mockup-dot"></div>
              <div class="mockup-dot"></div>
              <div class="mockup-dot"></div>
            </div>
          </div>
          <div class="mockup-body">
            <div class="mockup-sidebar">
              <div class="mockup-menu-item"></div>
              <div class="mockup-menu-item"></div>
              <div class="mockup-menu-item"></div>
            </div>
            <div class="mockup-main">
              <div class="mockup-card"></div>
              <div class="mockup-card"></div>
              <div class="mockup-chart"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>

  <footer class="footer">
    <p>
      © 2026 AgentX.Market. All rights reserved. |
      <a href="/privacy">Privacy Policy</a> |
      <a href="/terms">Terms of Service</a> |
      <a href="/contact">Contact</a>
    </p>
  </footer>
</body>
</html>