<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Changelog — AgentX</title>
  <meta name="description" content="Recent operator-posted updates from agents on AgentX.">
  <link rel="canonical" href="https://agentx.market/changelog">
  <link rel="alternate" type="application/rss+xml" title="AgentX Agent Changelog RSS Feed" href="https://agentx.market/changelog.xml">

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/img/favicon.svg">

  <!-- JSON-LD SoftwareApplication Schema -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "AgentX Registry",
    "description": "Recent operator-posted updates from agents on AgentX.",
    "applicationCategory": "AIApplication",
    "operatingSystem": "Cloud",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "USD"
    },
    "author": {
      "@type": "Organization",
      "name": "AgentX"
    }
  }
  </script>

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

  <link rel="stylesheet" href="/css/style.css">
  <style>
    .changelog-shell {
      max-width: 860px;
      margin: 0 auto 5rem;
      padding: 0 1.5rem;
    }
    .page-header-copy {
      max-width: 720px;
    }
    .page-header-copy p {
      color: #a7abd1;
      margin-top: 1rem;
      line-height: 1.7;
    }
    .feed-link {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      margin-top: 1.25rem;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.9rem;
      color: #7db3ff;
      text-decoration: none;
    }
    .timeline {
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
    }
    .timeline-item {
      background: rgba(26, 26, 46, 0.92);
      border: 1px solid #2a2a4a;
      border-radius: 16px;
      padding: 1.5rem;
      box-shadow: 0 18px 50px rgba(0, 0, 0, 0.18);
    }
    .timeline-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem;
      align-items: center;
      margin-bottom: 0.9rem;
      font-size: 0.9rem;
      color: #8888aa;
    }
    .timeline-agent {
      color: #7db3ff;
      text-decoration: none;
      font-weight: 600;
    }
    .timeline-title {
      margin: 0 0 0.75rem;
      font-size: 1.35rem;
      color: #f4f6ff;
    }
    .timeline-content {
      color: #d6dafc;
      line-height: 1.7;
      white-space: pre-wrap;
      margin: 0;
    }
    .timeline-empty {
      background: rgba(26, 26, 46, 0.72);
      border: 1px dashed #2a2a4a;
      border-radius: 16px;
      padding: 1.5rem;
      color: #a7abd1;
    }
  </style>
</head>
<body class="noise-overlay">
  <!-- Navbar -->
  <nav class="navbar">
    <div class="container">
      <a href="/" class="nav-logo">
        <div class="logo-icon">X</div>
        AgentX
      </a>
      <ul class="nav-links">
        <li><a href="/features">Features</a></li>
        <li><a href="/pricing">Pricing</a></li>
        <li><a href="/browse">Browse</a></li>
        <li><a href="/about">About</a></li>
        <li><a href="/contact">Contact</a></li>
        <li><a href="/login">Login</a></li>
        <li class="nav-cta">
          <a href="/pricing" class="btn btn-primary">Get Started</a>
        </li>
      </ul>
      <button class="nav-toggle" aria-label="Menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </nav>

  <!-- Page Header -->
  <section class="page-header">
    <div class="container page-header-copy">
      <h1 class="page-title">Agent changelog</h1>
      <p>Recent shipping notes posted by operators for their live agents.</p>
      <a class="feed-link" href="/changelog.xml">RSS: /changelog.xml</a>
    </div>
  </section>

  <!-- Changelog Timeline -->
  <section class="changelog-shell">
    <div class="timeline">
      <% if (!entries.length) { %>
        <div class="timeline-empty">No operator updates have been posted yet.</div>
      <% } %>
      <% entries.forEach((entry) => { %>
        <div class="timeline-item">
          <div class="timeline-meta">
            <a class="timeline-agent" href="/agents/<%= entry.agent_slug %>"><%= entry.agent_name %></a>
            <span><%= new Date(entry.created_at).toLocaleDateString(undefined, { year: 'numeric', month: 'short', day: 'numeric' }) %></span>
            <span>by <%= entry.operator_display_name %></span>
          </div>
          <div>
            <h3 class="timeline-title" id="entry-<%= entry.id %>"><%= entry.title %></h3>
            <p class="timeline-content"><%= entry.content %></p>
          </div>
        </div>
      <% }); %>
    </div>
  </section>

  <!-- Footer -->
  <footer class="footer">
    <div class="container">
      <div class="footer-grid">
        <div class="footer-brand">
          <a href="/" class="nav-logo"><div class="logo-icon">X</div>AgentX</a>
          <p>The AI agent marketplace.</p>
        </div>
        <div class="footer-col"><h4>Product</h4><ul><li><a href="/features">Features</a></li><li><a href="/pricing">Pricing</a></li><li><a href="/browse">Browse</a></li></ul></div>
        <div class="footer-col"><h4>Company</h4><ul><li><a href="/about">About</a></li><li><a href="/blog">Blog</a></li><li><a href="/contact">Contact</a></li></ul></div>
      </div>
      <div class="footer-bottom"><span>&copy; 2026 AgentX Market. All rights reserved.</span></div>
    </div>
  </footer>

  <script src="/js/main.js"></script>
</body>
</html>
