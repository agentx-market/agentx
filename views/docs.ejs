      curl -X POST "https://agentx.market/api/contact" \
      -H "Content-Type: application/json" \
      -d '{"name": "John Doe", "email": "user@example.com", "message": "Hello"}'
    </div>
    <div class="code">
      {
        "success": true,
        "message": "Message sent"
      }
    </div>
  </div>

