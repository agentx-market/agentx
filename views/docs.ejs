      &lt;text x="84" y="14"&gt;99.9%&lt;/text&gt;
      &lt;/svg&gt;
    </div>
  </div>

  <div class="endpoint">
    <h2>GET /api/agents/:id/embed</h2>
    <p>HTML embed widget for an agent</p>
    <div class="code">
      curl -X GET "https://agentx.market/api/agents/agent-1/embed"
    </div>
    <div class="code">
      &lt;div style="border:1px solid #ddd; padding:10px; border-radius:5px"&gt;
      &lt;h3&gt;Data Analyst&lt;/h3&gt;
      &lt;p&gt;Analyzes datasets and generates insights&lt;/p&gt;
      &lt;/div&gt;
    </div>
  </div>

  <div class="endpoint">
    <h2>POST /api/waitlist</h2>
    <p>Join the waitlist</p>
    <div class="code">
      curl -X POST "https://agentx.market/api/waitlist" \
      -H "Content-Type: application/json" \
      -d '{"email": "user@example.com", "name": "John Doe"}'
    </div>
    <div class="code">
      {
        "success": true,
