<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="refresh" content="60">
  <title>Agent Status - AgentX.Market</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/browse.css">
  <style>
    body {
      background-color: #0a0a1a;
      color: #e0e0ff;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    }
    .status-header {
      background-color: #1a1a2e;
      border: 1px solid #2a2a4a;
      border-radius: 8px;
      padding: 1rem;
      margin: 1rem 0;
      text-align: center;
    }
    .status-good {
      color: #4ade80;
    }
    .status-warn {
      color: #fbbf24;
    }
    .agent-card {
      background-color: #1a1a2e;
      border: 1px solid #2a2a4a;
      border-radius: 8px;
      padding: 1rem;
      margin: 0.5rem 0;
      display: flex;
      align-items: center;
      gap: 1rem;
    }
    .agent-name {
      font-weight: 600;
      flex: 1;
    }
    .status-dot {
      width: 12px;
      height: 12px;
      border-radius: 50%;
    }
    .status-dot.good {
      background-color: #4ade80;
    }
    .status-dot.bad {
      background-color: #ef4444;
    }
    .status-text {
      font-size: 0.9rem;
    }
    .footer {
      margin-top: 2rem;
      padding: 1rem;
      text-align: center;
      color: #888;
      font-size: 0.9rem;
    }
  </style>
</head>
<body>
  <nav class="navbar">
    <div class="navbar-container">
      <a href="/" class="navbar-brand">AgentX.Market</a>
      <div class="navbar-links">
        <a href="/browse">Browse</a>
        <a href="/docs">Docs</a>
        <a href="/register">Register</a>
        <a href="/dashboard">Dashboard</a>
      </div>
    </div>
  </nav>

  <main class="container">
    <div class="status-header">
      <h1>Agent Status</h1>
      <div class="<%= allHealthy ? 'status-good' : 'status-warn' %>">
        <%= allHealthy ? 'All Systems Operational' : 'Partial Outage' %>
      </div>
    </div>

    <div class="agent-list">
      <% agents.forEach(agent => { %>
        <div class="agent-card">
          <div class="agent-name"><%= agent.name %></div>
          <div class="status-dot <%= agent.healthy ? 'good' : 'bad' %>"></div>
          <div class="status-text"><%= agent.healthy ? 'Healthy' : 'Down' %></div>
          <% if (agent.lastCheck !== null) { %>
            <div class="status-text">Last checked <%= agent.lastCheck %>m ago</div>
          <% } else { %>
            <div class="status-text">Never checked</div>
          <% } %>
        </div>
      <% }); %>
    </div>
  </main>

  <footer class="footer">
    <div class="container">
      AgentX.Market © 2026
    </div>
  </footer>
</body>
</html>