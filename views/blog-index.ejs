<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Blog — AgentX</title>
  <meta name="description" content="Latest articles about autonomous agents and AI infrastructure">

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/img/favicon.svg">

  <!-- JSON-LD SoftwareApplication Schema -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "AgentX Registry",
    "description": "Latest articles about autonomous agents and AI infrastructure",
    "applicationCategory": "AIApplication",
    "operatingSystem": "Cloud",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "USD"
    },
    "author": {
      "@type": "Organization",
      "name": "AgentX"
    }
  }
  </script>

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="noise-overlay">
  <!-- Navbar -->
  <nav class="navbar">
    <div class="container">
      <a href="/" class="nav-logo">
        <div class="logo-icon">X</div>
        AgentX
      </a>
      <ul class="nav-links">
        <li><a href="/features">Features</a></li>
        <li><a href="/pricing">Pricing</a></li>
        <li><a href="/browse">Browse</a></li>
        <li><a href="/about">About</a></li>
        <li><a href="/contact">Contact</a></li>
        <li><a href="/login">Login</a></li>
        <li class="nav-cta">
          <a href="/pricing" class="btn btn-primary">Get Started</a>
        </li>
      </ul>
      <button class="nav-toggle" aria-label="Menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </nav>

  <!-- Page Header -->
  <section class="page-hero">
    <div class="bg-grid"></div>
    <div class="container relative z-1">
      <div class="badge fade-in">Blog</div>
      <h1 class="fade-in fade-in-delay-1">Latest from <span class="text-gradient">AgentX</span></h1>
      <p class="large fade-in fade-in-delay-2">Insights on autonomous agents, AI infrastructure, and the future of work.</p>
    </div>
  </section>

  <!-- Blog Content -->
  <section class="blog-main">
    <div class="container">
      <div class="blog-grid">
        <% posts.forEach(post => { %>
        <article class="blog-card fade-in">
          <div class="blog-card-header">
            <h2 class="blog-card-title">
              <a href="/blog/<%= post.slug %>"><%= post.title %></a>
            </h2>
            <time class="blog-card-date" datetime="<%= post.date %>"><%= post.date %></time>
          </div>
          <div class="blog-card-body">
            <p class="blog-card-excerpt"><%= post.description %></p>
          </div>
          <div class="blog-card-footer">
            <a href="/blog/<%= post.slug %>">Read More</a>
          </div>
        </article>
        <% }); %>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="footer">
    <div class="container">
      <div class="footer-grid">
        <div class="footer-brand">
          <a href="/" class="nav-logo" style="margin-bottom: 0.5rem;">
            <div class="logo-icon">X</div>
            AgentX
          </a>
          <p>The AI agent marketplace. Discover, deploy, and manage autonomous agents that handle real business tasks.</p>
        </div>
        <div class="footer-col">
          <h4>Product</h4>
          <ul>
            <li><a href="/features">Features</a></li>
            <li><a href="/pricing">Pricing</a></li>
            <li><a href="/browse">Browse Agents</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h4>Company</h4>
          <ul>
            <li><a href="/about">About</a></li>
            <li><a href="/blog">Blog</a></li>
            <li><a href="/contact">Contact</a></li>
          </ul>
        </div>
      </div>
      <div class="footer-bottom">
        <span>&copy; 2026 AgentX Market. All rights reserved.</span>
      </div>
    </div>
  </footer>

  <script src="/js/main.js"></script>
</body>
</html>