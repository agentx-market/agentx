<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - AgentX</title>
  <link rel="stylesheet" href="/css/style.css">
  <style>
    .newsletter-admin { padding: 2rem 0 4rem; }
    .admin-grid { display: grid; gap: 1.5rem; grid-template-columns: minmax(0, 1.05fr) minmax(320px, 0.95fr); align-items: start; }
    .admin-card { background: #1a1a2e; border: 1px solid #2a2a4a; border-radius: 14px; padding: 1.35rem; }
    .admin-card h2, .admin-card h3 { margin-top: 0; color: #e0e0ff; }
    .admin-meta { color: #98a2c9; margin-bottom: 1rem; }
    .slot-list { display: grid; gap: 0.9rem; }
    .slot-item { border: 1px solid #2a2a4a; border-radius: 12px; padding: 1rem; background: rgba(255,255,255,0.02); }
    .slot-item strong { color: #e0e0ff; }
    .slot-open { color: #4be28a; }
    .slot-booked { color: #ffcc66; }
    .form-grid { display: grid; gap: 0.85rem; }
    .form-row { display: grid; gap: 0.85rem; grid-template-columns: repeat(2, minmax(0, 1fr)); }
    label { display: block; color: #cfd6f4; font-size: 0.92rem; margin-bottom: 0.35rem; }
    input, select, textarea { width: 100%; border-radius: 10px; border: 1px solid #2a2a4a; background: #0f1020; color: #edf1ff; padding: 0.8rem 0.9rem; font: inherit; }
    textarea { min-height: 110px; resize: vertical; }
    .helper { margin-top: 0.3rem; font-size: 0.8rem; color: #8f95b2; }
    .preview-shell { background: #f1f6ff; color: #10233f; border-radius: 16px; padding: 1.25rem; }
    .preview-shell h3 { color: #10233f; }
    .preview-copy { color: #31425f; line-height: 1.65; }
    .status-line { min-height: 1.4rem; color: #8f95b2; }
    .status-line.error { color: #ff7d7d; }
    .status-line.success { color: #4be28a; }
    @media (max-width: 960px) {
      .admin-grid, .form-row { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>
  <nav class="navbar">
    <div class="container">
      <a href="/" class="nav-logo"><div class="logo-icon">X</div>AgentX</a>
      <ul class="nav-links">
        <li><a href="/browse">Browse</a></li>
        <li><a href="/my-agents">Dashboard</a></li>
        <li class="nav-cta"><a href="/dashboard/billing" class="btn btn-primary">Billing</a></li>
      </ul>
      <button class="nav-toggle" aria-label="Menu"><span></span><span></span><span></span></button>
    </div>
  </nav>

  <section class="dashboard-hero">
    <div class="bg-grid"></div>
    <div class="container">
      <div class="section-header fade-in">
        <div class="badge badge-shimmer"><span class="dot"></span> Newsletter Admin</div>
        <h1>Weekly Sponsorship <span class="text-gradient">Slots</span></h1>
        <p>Assign featured newsletter placements, create invoice-backed charges, and preview what subscribers will receive.</p>
      </div>
    </div>
  </section>

  <section class="newsletter-admin">
    <div class="container">
      <div class="admin-grid">
        <div class="admin-card">
          <h2>Issue Schedule</h2>
          <p class="admin-meta">Week of <strong id="week-label"><%= slotData.weekStart %></strong> · <%= slotsPerIssue %> slots · $<%= slotPriceUsd %> each</p>
          <div class="form-row">
            <div>
              <label for="weekStart">Issue week</label>
              <input id="weekStart" type="date" value="<%= weekStart %>">
            </div>
            <div>
              <label>&nbsp;</label>
              <button id="refresh-slots" class="btn btn-secondary" type="button">Load Slots</button>
            </div>
          </div>
          <div class="slot-list" id="slot-list">
            <% slotData.slots.forEach(function(slot) { %>
              <div class="slot-item">
                <strong>Slot <%= slot.slotPosition %></strong>
                <% if (slot.available) { %>
                  <div class="slot-open">Available</div>
                <% } else { %>
                  <div class="slot-booked">Booked by <%= slot.booking.sponsorName %> · invoice #<%= slot.booking.invoiceId %></div>
                <% } %>
              </div>
            <% }) %>
          </div>
        </div>

        <div class="admin-card">
          <h2>Book Sponsor Slot</h2>
          <form id="booking-form" class="form-grid">
            <div class="form-row">
              <div>
                <label for="operatorId">Operator</label>
                <select id="operatorId" name="operatorId" required>
                  <option value="">Select operator</option>
                  <% operators.forEach(function(entry) { %>
                    <option value="<%= entry.id %>"><%= entry.name || entry.email || entry.id %> (<%= entry.id %>)</option>
                  <% }) %>
                </select>
              </div>
              <div>
                <label for="slotPosition">Slot position</label>
                <select id="slotPosition" name="slotPosition" required>
                  <% for (let index = 1; index <= slotsPerIssue; index += 1) { %>
                    <option value="<%= index %>">Slot <%= index %></option>
                  <% } %>
                </select>
              </div>
            </div>
            <div>
              <label for="sponsorName">Sponsor name</label>
              <input id="sponsorName" name="sponsorName" maxlength="80" required>
            </div>
            <div class="form-row">
              <div>
                <label for="sponsorUrl">Destination URL</label>
                <input id="sponsorUrl" name="sponsorUrl" type="url" placeholder="https://example.com" required>
              </div>
              <div>
                <label for="logoUrl">Logo URL</label>
                <input id="logoUrl" name="logoUrl" type="url" placeholder="https://example.com/logo.png" required>
              </div>
            </div>
            <div>
              <label for="blurb">Short blurb</label>
              <textarea id="blurb" name="blurb" maxlength="220" required></textarea>
              <div class="helper">Max 220 characters. This renders with a visible “Sponsored” label in the newsletter preview.</div>
            </div>
            <button class="btn btn-primary" type="submit">Book For $<%= slotPriceUsd %></button>
            <div id="status-line" class="status-line"></div>
          </form>
        </div>
      </div>

      <div class="admin-card" style="margin-top: 1.5rem;">
        <h2>Subscriber Preview</h2>
        <div class="preview-shell">
          <h3>This week on AgentX</h3>
          <p class="preview-copy">Marketplace launches, operator updates, and one featured sponsor block appear below exactly as the weekly newsletter would present them.</p>
          <div id="newsletter-preview"><%- slotData.sponsoredHtml || '<p class="preview-copy">No sponsored content scheduled for this issue yet.</p>' %></div>
        </div>
      </div>
    </div>
  </section>

  <script>
    const weekInput = document.getElementById('weekStart');
    const refreshButton = document.getElementById('refresh-slots');
    const slotList = document.getElementById('slot-list');
    const preview = document.getElementById('newsletter-preview');
    const statusLine = document.getElementById('status-line');
    const bookingForm = document.getElementById('booking-form');
    const weekLabel = document.getElementById('week-label');

    function setStatus(message, type) {
      statusLine.textContent = message || '';
      statusLine.className = 'status-line' + (type ? ' ' + type : '');
    }

    function renderSlots(data) {
      weekLabel.textContent = data.weekStart;
      slotList.innerHTML = data.slots.map((slot) => {
        if (slot.available) {
          return '<div class="slot-item"><strong>Slot ' + slot.slotPosition + '</strong><div class="slot-open">Available</div></div>';
        }
        return '<div class="slot-item"><strong>Slot ' + slot.slotPosition + '</strong><div class="slot-booked">Booked by ' + slot.booking.sponsorName + ' · invoice #' + slot.booking.invoiceId + '</div></div>';
      }).join('');

      preview.innerHTML = data.sponsoredHtml || '<p class="preview-copy">No sponsored content scheduled for this issue yet.</p>';
    }

    async function loadSlots() {
      setStatus('');
      const response = await fetch('/api/newsletter/slots?weekStart=' + encodeURIComponent(weekInput.value));
      const data = await response.json();
      if (!response.ok) {
        throw new Error(data.error || 'Failed to load slots');
      }
      renderSlots(data);
      return data;
    }

    refreshButton.addEventListener('click', async () => {
      try {
        await loadSlots();
      } catch (error) {
        setStatus(error.message, 'error');
      }
    });

    bookingForm.addEventListener('submit', async (event) => {
      event.preventDefault();
      setStatus('Creating booking and invoice...');

      const payload = {
        operatorId: document.getElementById('operatorId').value,
        weekStart: weekInput.value,
        slotPosition: document.getElementById('slotPosition').value,
        sponsorName: document.getElementById('sponsorName').value,
        sponsorUrl: document.getElementById('sponsorUrl').value,
        logoUrl: document.getElementById('logoUrl').value,
        blurb: document.getElementById('blurb').value
      };

      try {
        const response = await fetch('/api/newsletter/book', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
        });
        const data = await response.json();
        if (!response.ok) {
          throw new Error(data.error || 'Booking failed');
        }

        setStatus('Booked slot and issued invoice #' + data.invoiceId + '.', 'success');
        bookingForm.reset();
        await loadSlots();
      } catch (error) {
        setStatus(error.message, 'error');
      }
    });
  </script>
</body>
</html>
