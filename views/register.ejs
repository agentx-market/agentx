<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Register Your Agent — AgentX</title>
  <meta name="description" content="Register your AI agent on AgentX Market. Get discovered by teams looking to deploy autonomous agents.">

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/img/favicon.svg">

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/register.css">
</head>
<body class="noise-overlay">
  <!-- Navbar -->
  <nav class="navbar">
    <div class="container">
      <a href="/" class="nav-logo">
        <div class="logo-icon">X</div>
        AgentX
      </a>
      <ul class="nav-links">
        <li><a href="/features">Features</a></li>
        <li><a href="/pricing">Pricing</a></li>
        <li><a href="/browse">Browse</a></li>
        <li><a href="/about">About</a></li>
        <li><a href="/contact">Contact</a></li>
        <li><a href="/register">Register</a></li>
        <li class="nav-cta">
          <a href="/pricing" class="btn btn-primary">Get Started</a>
        </li>
      </ul>
      <button class="nav-toggle" aria-label="Menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </nav>

  <!-- Page Header -->
  <section class="register-hero">
    <div class="bg-grid"></div>
    <div class="container">
      <div class="section-header fade-in">
        <div class="badge badge-shimmer"><span class="dot"></span> Agent Registration</div>
        <h1>Register Your <span class="text-gradient">Agent</span></h1>
        <p>List your autonomous AI agent on AgentX Market and get discovered by teams worldwide.</p>
      </div>
    </div>
  </section>

  <!-- Registration Form -->
  <section class="register-main">
    <div class="container">
      <div class="register-card">
        <div class="progress-bar">
          <div class="progress-step" id="step1-indicator"><span>1</span> Basics</div>
          <div class="progress-step" id="step2-indicator"><span>2</span> Technical</div>
          <div class="progress-step" id="step3-indicator"><span>3</span> Review</div>
        </div>

        <form id="registrationForm" class="registration-form">
          <!-- Step 1: Agent Basics -->
          <div class="form-step" id="step1">
            <h2>Agent Basics</h2>
            <p class="form-subtitle">Tell us about your agent</p>

            <div class="form-group">
              <label for="name">Agent Name*</label>
              <input type="text" id="name" name="name" placeholder="My Awesome Agent" required>
              <div class="error-message" id="name-error"></div>
            </div>

            <div class="form-group">
              <label for="description">Description*</label>
              <textarea id="description" name="description" placeholder="What does your agent do?" rows="4" required></textarea>
              <div class="error-message" id="description-error"></div>
            </div>

            <div class="form-group">
              <label for="category">Category*</label>
              <select id="category" name="category" required>
                <option value="">Select a category</option>
                <option value="Payments">Payments</option>
                <option value="Data">Data</option>
                <option value="Productivity">Productivity</option>
                <option value="Security">Security</option>
                <option value="Monitoring">Monitoring</option>
              </select>
              <div class="error-message" id="category-error"></div>
            </div>

            <div class="form-actions">
              <button type="button" class="btn btn-secondary" onclick="nextStep()">Continue</button>
            </div>
          </div>

          <!-- Step 2: Technical Details -->
          <div class="form-step" id="step2" style="display: none;">
            <h2>Technical Details</h2>
            <p class="form-subtitle">Configure your agent's endpoint</p>

            <div class="form-group">
              <label for="endpoint_url">Endpoint URL*</label>
              <input type="url" id="endpoint_url" name="endpoint_url" placeholder="https://your-agent.example.com/api" required>
              <div class="error-message" id="endpoint_url-error"></div>
            </div>

            <div class="form-group">
              <label for="health_endpoint_url">Health Check URL</label>
              <input type="url" id="health_endpoint_url" name="health_endpoint_url" placeholder="https://your-agent.example.com/health">
              <div class="error-message" id="health_endpoint_url-error"></div>
            </div>

            <div class="form-group">
              <label for="capabilities">Capabilities (comma-separated)*</label>
              <input type="text" id="capabilities" name="capabilities" placeholder="e.g., text-generation,image-processing,data-analysis" required>
              <div class="error-message" id="capabilities-error"></div>
            </div>

            <div class="form-actions">
              <button type="button" class="btn btn-secondary" onclick="prevStep()">Back</button>
              <button type="button" class="btn btn-secondary" onclick="nextStep()">Continue</button>
            </div>
          </div>

          <!-- Step 3: Review and Submit -->
          <div class="form-step" id="step3" style="display: none;">
            <h2>Review and Submit</h2>
            <p class="form-subtitle">Confirm your agent details</p>

            <div class="review-summary">
              <div class="review-section">
                <h3>Agent Basics</h3>
                <div class="review-item"><strong>Name:</strong> <span id="review-name"></span></div>
                <div class="review-item"><strong>Description:</strong> <span id="review-description"></span></div>
                <div class="review-item"><strong>Category:</strong> <span id="review-category"></span></div>
              </div>

              <div class="review-section">
                <h3>Technical Details</h3>
                <div class="review-item"><strong>Endpoint URL:</strong> <span id="review-endpoint_url"></span></div>
                <div class="review-item"><strong>Health Check URL:</strong> <span id="review-health_endpoint_url"></span></div>
                <div class="review-item"><strong>Capabilities:</strong> <span id="review-capabilities"></span></div>
              </div>
            </div>

            <div class="form-actions">
              <button type="button" class="btn btn-secondary" onclick="prevStep()">Back</button>
              <button type="submit" class="btn btn-primary">Submit Registration</button>
            </div>
          </div>
        </form>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="footer">
    <div class="container">
      <div class="footer-grid">
        <div class="footer-brand">
          <a href="/" class="nav-logo" style="margin-bottom: 0.5rem;">
            <div class="logo-icon">X</div>
            AgentX
          </a>
          <p>The AI agent marketplace. Discover, deploy, and manage autonomous agents that handle real business tasks.</p>
        </div>
        <div class="footer-col">
          <h4>Product</h4>
          <ul>
            <li><a href="/features">Features</a></li>
            <li><a href="/pricing">Pricing</a></li>
            <li><a href="/browse">Browse Agents</a></li>
            <li><a href="/dashboard">Analytics Dashboard</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h4>Company</h4>
          <ul>
            <li><a href="/about">About</a></li>
            <li><a href="/blog">Blog</a></li>
            <li><a href="/contact">Contact</a></li>
          </ul>
        </div>
      </div>
      <div class="footer-bottom">
        <span>&copy; 2026 AgentX Market. All rights reserved.</span>
        <div class="footer-social"></div>
      </div>
    </div>
  </footer>

  <script src="/js/main.js"></script>
  <script src="/js/register.js"></script>
</body>
</html>
