<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <meta name="description" content="<%= description %>">
  <link rel="canonical" href="<%= canonicalUrl %>">

  <meta property="og:type" content="website">
  <meta property="og:url" content="<%= canonicalUrl %>">
  <meta property="og:title" content="<%= title %>">
  <meta property="og:description" content="<%= description %>">
  <meta property="og:image" content="https://agentx.market/img/og-image.png">
  <meta property="og:site_name" content="AgentX">

  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:site" content="@agentxmarket">
  <meta name="twitter:title" content="<%= title %>">
  <meta name="twitter:description" content="<%= description %>">

  <link rel="icon" type="image/svg+xml" href="/img/favicon.svg">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">

  <script type="application/ld+json"><%- itemListSchema %></script>
  <script type="application/ld+json"><%- faqSchema %></script>

  <style>
    .seo-shell {
      background:
        radial-gradient(circle at top left, rgba(79, 195, 247, 0.14), transparent 28rem),
        radial-gradient(circle at top right, rgba(76, 175, 80, 0.1), transparent 24rem),
        #0a0a1a;
      min-height: 100vh;
    }

    .seo-page {
      padding: 4rem 0 5rem;
    }

    .seo-hero,
    .seo-section,
    .seo-card,
    .faq-item,
    .related-card {
      background: rgba(26, 26, 46, 0.88);
      border: 1px solid rgba(74, 74, 122, 0.7);
      box-shadow: 0 24px 70px rgba(5, 10, 30, 0.26);
    }

    .seo-hero {
      border-radius: 28px;
      padding: 3rem;
      margin-bottom: 2rem;
    }

    .seo-kicker {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.45rem 0.8rem;
      border-radius: 999px;
      background: rgba(79, 195, 247, 0.12);
      color: #8fdcff;
      font-size: 0.82rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      margin-bottom: 1rem;
    }

    .seo-hero h1 {
      margin: 0 0 1rem;
      font-size: clamp(2rem, 4vw, 3.6rem);
      line-height: 1.05;
    }

    .seo-hero p {
      color: #c7c7e8;
      max-width: 52rem;
      font-size: 1.05rem;
      line-height: 1.7;
    }

    .seo-section {
      border-radius: 24px;
      padding: 2rem;
      margin-bottom: 1.5rem;
    }

    .seo-section h2 {
      margin-top: 0;
      margin-bottom: 1rem;
      font-size: 1.55rem;
    }

    .intro-copy p {
      margin: 0 0 1rem;
      color: #c7c7e8;
      line-height: 1.78;
    }

    .intro-copy p:last-child {
      margin-bottom: 0;
    }

    .agent-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1rem;
    }

    .seo-card {
      border-radius: 20px;
      padding: 1.25rem;
      display: flex;
      flex-direction: column;
      min-height: 100%;
    }

    .seo-card-header {
      display: flex;
      justify-content: space-between;
      gap: 0.75rem;
      align-items: flex-start;
      margin-bottom: 0.85rem;
    }

    .seo-card h3 {
      margin: 0;
      font-size: 1.1rem;
    }

    .seo-card h3 a {
      color: #f8fbff;
      text-decoration: none;
    }

    .seo-card h3 a:hover {
      color: #8fdcff;
    }

    .card-badge {
      font-size: 0.72rem;
      white-space: nowrap;
      padding: 0.32rem 0.55rem;
      border-radius: 999px;
      background: rgba(143, 220, 255, 0.12);
      color: #8fdcff;
    }

    .seo-card p {
      margin: 0 0 1rem;
      color: #c7c7e8;
      line-height: 1.65;
      flex: 1;
    }

    .meta-row,
    .chip-row {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
    }

    .meta-pill,
    .chip {
      border-radius: 999px;
      border: 1px solid rgba(74, 74, 122, 0.8);
      padding: 0.35rem 0.7rem;
      color: #d5ddff;
      background: rgba(10, 10, 26, 0.6);
      font-size: 0.85rem;
    }

    .seo-card .btn {
      margin-top: 1rem;
      width: fit-content;
    }

    .faq-list,
    .related-grid {
      display: grid;
      gap: 1rem;
    }

    .faq-item,
    .related-card {
      border-radius: 18px;
      padding: 1.2rem;
    }

    .faq-item h3,
    .related-card h3 {
      margin-top: 0;
      margin-bottom: 0.65rem;
      font-size: 1.05rem;
    }

    .faq-item p,
    .related-card p {
      margin: 0;
      color: #c7c7e8;
      line-height: 1.7;
    }

    .related-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .related-card a {
      color: inherit;
      text-decoration: none;
      display: block;
    }

    @media (max-width: 960px) {
      .agent-grid,
      .related-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 720px) {
      .seo-page {
        padding: 2rem 0 4rem;
      }

      .seo-hero,
      .seo-section {
        padding: 1.4rem;
        border-radius: 20px;
      }

      .agent-grid,
      .related-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</head>
<body class="noise-overlay seo-shell">
  <nav class="navbar">
    <div class="container">
      <a href="/" class="nav-logo">
        <div class="logo-icon">X</div>
        AgentX
      </a>
      <ul class="nav-links">
        <li><a href="/features">Features</a></li>
        <li><a href="/pricing">Pricing</a></li>
        <li><a href="/browse">Browse</a></li>
        <li><a href="/about">About</a></li>
        <li><a href="/contact">Contact</a></li>
        <li><a href="/login">Login</a></li>
        <li class="nav-cta"><a href="/pricing" class="btn btn-primary">Get Started</a></li>
      </ul>
      <button class="nav-toggle" aria-label="Menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </nav>

  <main class="seo-page">
    <div class="container">
      <section class="seo-hero">
        <div class="seo-kicker">SEO Landing Page</div>
        <h1><%= h1 %></h1>
        <p>Find a focused shortlist of <%= exactKeyword %> with a category overview, six matching listings, and internal paths to adjacent buying intent pages.</p>
      </section>

      <section class="seo-section">
        <h2>Why teams search for <%= exactKeyword %></h2>
        <div class="intro-copy">
          <% introParagraphs.forEach((paragraph) => { %>
            <p><%= paragraph %></p>
          <% }) %>
        </div>
      </section>

      <section class="seo-section">
        <h2>Best matching agents</h2>
        <div class="agent-grid">
          <% agents.forEach((agent, index) => { %>
            <article class="seo-card" itemscope itemtype="https://schema.org/SoftwareApplication">
              <meta itemprop="applicationCategory" content="<%= page.displayName %>">
              <meta itemprop="operatingSystem" content="Cloud">
              <meta itemprop="url" content="https://agentx.market/agents/<%= agent.slug %>">
              <div class="seo-card-header">
                <h3 itemprop="name"><a href="/agents/<%= agent.slug %>"><%= agent.name %></a></h3>
                <span class="card-badge"><%= index + 1 %> / 6</span>
              </div>
              <p itemprop="description"><%= agent.description %></p>
              <div class="meta-row">
                <span class="meta-pill"><%= agent.uptimeLabel %></span>
                <span class="meta-pill" itemprop="offers" itemscope itemtype="https://schema.org/Offer">
                  <meta itemprop="priceCurrency" content="USD">
                  <meta itemprop="price" content="<%= agent.structuredDataPrice %>">
                  <span itemprop="description"><%= agent.pricingLabel %></span>
                </span>
              </div>
              <% if (agent.capabilitiesList.length > 0 || agent.categories.length > 0) { %>
                <div class="chip-row" style="margin-top: 0.9rem;">
                  <% agent.capabilitiesList.forEach((capability) => { %>
                    <span class="chip"><%= capability %></span>
                  <% }) %>
                  <% if (agent.capabilitiesList.length === 0) { %>
                    <% agent.categories.slice(0, 3).forEach((category) => { %>
                      <span class="chip"><%= category %></span>
                    <% }) %>
                  <% } %>
                </div>
              <% } %>
              <a href="/agents/<%= agent.slug %>" class="btn btn-secondary">View agent</a>
            </article>
          <% }) %>
        </div>
      </section>

      <section class="seo-section">
        <h2>Frequently asked questions</h2>
        <div class="faq-list">
          <% faqs.forEach((faq) => { %>
            <article class="faq-item">
              <h3><%= faq.q %></h3>
              <p><%= faq.a %></p>
            </article>
          <% }) %>
        </div>
      </section>

      <section class="seo-section">
        <h2>Related categories</h2>
        <div class="related-grid">
          <% relatedPages.forEach((relatedPage) => { %>
            <article class="related-card">
              <a href="/<%= relatedPage.slug %>-ai-agents">
                <h3><%= relatedPage.displayName %> AI agents</h3>
                <p>Explore the adjacent buying-intent page for <%= relatedPage.displayName.toLowerCase() %> workflows and compare overlap before you shortlist a vendor.</p>
              </a>
            </article>
          <% }) %>
        </div>
      </section>
    </div>
  </main>

  <footer class="footer">
    <div class="container">
      <div class="footer-grid">
        <div class="footer-brand">
          <a href="/" class="nav-logo" style="margin-bottom: 0.5rem;">
            <div class="logo-icon">X</div>
            AgentX
          </a>
          <p>The AI agent marketplace. Discover, compare, and deploy AI agents for real work.</p>
        </div>
        <div class="footer-col">
          <h4>Product</h4>
          <ul>
            <li><a href="/features">Features</a></li>
            <li><a href="/pricing">Pricing</a></li>
            <li><a href="/browse">Browse Agents</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h4>Company</h4>
          <ul>
            <li><a href="/about">About</a></li>
            <li><a href="/blog">Blog</a></li>
            <li><a href="/contact">Contact</a></li>
          </ul>
        </div>
      </div>
      <div class="footer-bottom">
        <span>&copy; 2026 AgentX Market. All rights reserved.</span>
      </div>
    </div>
  </footer>

  <script src="/js/main.js"></script>
</body>
</html>
