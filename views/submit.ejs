<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Submit an Agent - AgentX.Market</title>
  <meta name="description" content="List your agent on AgentX without an API integration. Submit the basics, trigger an automated health check, and enter the review queue.">
  <style>
    :root {
      --bg: #111827;
      --panel: rgba(17, 24, 39, 0.92);
      --panel-soft: rgba(31, 41, 55, 0.9);
      --border: rgba(148, 163, 184, 0.22);
      --text: #e5eefb;
      --muted: #9fb0ca;
      --accent: #f97316;
      --accent-strong: #ea580c;
      --success: #22c55e;
      --danger: #f87171;
      --shadow: 0 32px 64px rgba(15, 23, 42, 0.32);
    }

    * { box-sizing: border-box; }
    body {
      margin: 0;
      min-height: 100vh;
      color: var(--text);
      font-family: "Manrope", "Helvetica Neue", Arial, sans-serif;
      background:
        radial-gradient(circle at top left, rgba(249, 115, 22, 0.22), transparent 28%),
        radial-gradient(circle at right 20%, rgba(56, 189, 248, 0.12), transparent 24%),
        linear-gradient(180deg, #0b1120 0%, var(--bg) 100%);
    }
    .wrap { max-width: 1120px; margin: 0 auto; padding: 28px 20px 64px; }
    .nav { display: flex; justify-content: space-between; align-items: center; margin-bottom: 28px; }
    .brand, .nav a { color: var(--text); text-decoration: none; }
    .brand { font-weight: 800; letter-spacing: 0.08em; text-transform: uppercase; }
    .nav-links { display: flex; gap: 18px; }
    .hero {
      display: grid;
      gap: 20px;
      grid-template-columns: minmax(0, 1.2fr) minmax(280px, 0.8fr);
      margin-bottom: 24px;
    }
    .card {
      border: 1px solid var(--border);
      border-radius: 28px;
      background: var(--panel);
      box-shadow: var(--shadow);
      backdrop-filter: blur(12px);
    }
    .hero-main { padding: 34px; }
    .hero-side { padding: 30px; background: var(--panel-soft); }
    .eyebrow {
      display: inline-block;
      margin-bottom: 14px;
      color: #fdba74;
      font-size: 0.78rem;
      font-weight: 800;
      letter-spacing: 0.14em;
      text-transform: uppercase;
    }
    h1 { margin: 0 0 14px; font-size: clamp(2.6rem, 6vw, 4.8rem); line-height: 0.95; }
    .lede, .hero-side p, .hero-side li, .field-help, .message { color: var(--muted); line-height: 1.7; }
    .hero-side ul { margin: 0; padding-left: 18px; }
    .hero-side li + li { margin-top: 10px; }
    .hero-side a {
      color: var(--text);
      font-weight: 700;
      text-decoration: none;
    }
    .form-card { padding: 34px; }
    .form-grid {
      display: grid;
      gap: 18px;
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
    .field.full { grid-column: 1 / -1; }
    label {
      display: block;
      margin-bottom: 8px;
      font-size: 0.92rem;
      font-weight: 700;
    }
    input, textarea, select {
      width: 100%;
      padding: 14px 16px;
      border: 1px solid var(--border);
      border-radius: 16px;
      background: rgba(15, 23, 42, 0.78);
      color: var(--text);
      font: inherit;
    }
    textarea { min-height: 150px; resize: vertical; }
    input:focus, textarea:focus, select:focus {
      outline: 2px solid rgba(249, 115, 22, 0.24);
      border-color: rgba(249, 115, 22, 0.75);
    }
    .field-help { margin: 8px 0 0; font-size: 0.9rem; }
    .actions {
      display: flex;
      align-items: center;
      gap: 14px;
      margin-top: 24px;
      flex-wrap: wrap;
    }
    button {
      border: 0;
      border-radius: 999px;
      padding: 14px 22px;
      background: linear-gradient(135deg, var(--accent), var(--accent-strong));
      color: white;
      font: inherit;
      font-weight: 800;
      cursor: pointer;
    }
    button:disabled { opacity: 0.72; cursor: wait; }
    .message {
      display: none;
      margin-top: 20px;
      padding: 15px 16px;
      border-radius: 16px;
      border: 1px solid transparent;
    }
    .message.visible { display: block; }
    .message.success {
      color: #d8ffe5;
      background: rgba(34, 197, 94, 0.12);
      border-color: rgba(34, 197, 94, 0.28);
    }
    .message.error {
      color: #ffe2e2;
      background: rgba(248, 113, 113, 0.12);
      border-color: rgba(248, 113, 113, 0.24);
    }

    @media (max-width: 860px) {
      .hero, .form-grid { grid-template-columns: 1fr; }
      .hero-main, .hero-side, .form-card { padding: 24px; }
      .wrap { padding-top: 20px; }
    }
  </style>
</head>
<body>
  <div class="wrap">
    <nav class="nav">
      <a class="brand" href="/">AgentX</a>
      <div class="nav-links">
        <a href="/browse">Browse</a>
        <a href="/register">Register</a>
      </div>
    </nav>

    <section class="hero">
      <div class="card hero-main">
        <span class="eyebrow">Public Submission</span>
        <h1>Submit your agent without touching the API.</h1>
        <p class="lede">Add the basics, we run a live check against the submitted endpoint, and the listing either goes live immediately or lands in the pending review queue.</p>
      </div>
      <aside class="card hero-side">
        <h2>What happens next</h2>
        <ul>
          <li>If the submitted endpoint returns HTTP 200, the listing is auto-approved.</li>
          <li>If not, the submission stays in the pending review queue for manual review.</li>
          <li>We email a confirmation either way so the submitter knows the outcome.</li>
        </ul>
        <p><a href="/register">Need full operator controls instead?</a></p>
      </aside>
    </section>

    <section class="card form-card">
      <h2>Agent details</h2>
      <form id="submitForm">
        <div class="form-grid">
          <div class="field">
            <label for="agentName">Agent name</label>
            <input id="agentName" name="agentName" type="text" maxlength="100" required placeholder="Acme Support Agent">
          </div>
          <div class="field">
            <label for="endpointUrl">URL / endpoint</label>
            <input id="endpointUrl" name="endpointUrl" type="url" maxlength="500" required placeholder="https://agent.example.com">
            <p class="field-help">This URL is also used for the automated health check in the first pass.</p>
          </div>
          <div class="field full">
            <label for="description">Description</label>
            <textarea id="description" name="description" maxlength="500" required placeholder="What does the agent do, and who is it for?"></textarea>
          </div>
          <div class="field">
            <label for="category">Category</label>
            <select id="category" name="category" required>
              <option value="">Select a category</option>
              <% categories.forEach((category) => { %>
                <option value="<%= category.slug %>"><%= category.name %></option>
              <% }) %>
            </select>
          </div>
          <div class="field">
            <label for="pricingModel">Pricing model</label>
            <select id="pricingModel" name="pricingModel" required>
              <option value="">Select pricing</option>
              <option value="free">Free</option>
              <option value="paid">Paid</option>
              <option value="freemium">Freemium</option>
            </select>
          </div>
          <div class="field">
            <label for="logoUrl">Logo URL</label>
            <input id="logoUrl" name="logoUrl" type="url" maxlength="500" placeholder="https://agent.example.com/logo.png">
          </div>
          <div class="field">
            <label for="contactEmail">Contact email</label>
            <input id="contactEmail" name="contactEmail" type="email" maxlength="254" required placeholder="operator@example.com">
          </div>
        </div>
        <div class="actions">
          <button id="submitButton" type="submit">Submit agent</button>
        </div>
      </form>
      <div id="message" class="message" aria-live="polite"></div>
    </section>
  </div>

  <script>
    const form = document.getElementById('submitForm');
    const submitButton = document.getElementById('submitButton');
    const message = document.getElementById('message');

    function showMessage(type, text) {
      message.className = `message visible ${type}`;
      message.textContent = text;
    }

    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      submitButton.disabled = true;
      showMessage('success', 'Submitting your listing...');

      try {
        const response = await fetch('/api/submit-agent', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            agentName: form.agentName.value.trim(),
            endpointUrl: form.endpointUrl.value.trim(),
            description: form.description.value.trim(),
            category: form.category.value,
            pricingModel: form.pricingModel.value,
            logoUrl: form.logoUrl.value.trim(),
            contactEmail: form.contactEmail.value.trim()
          })
        });

        const data = await response.json();
        if (!response.ok) {
          throw new Error(data.error || 'Submission failed');
        }

        if (data.autoApproved && data.listingUrl) {
          showMessage('success', `Approved. Your listing is live at ${data.listingUrl}. We also sent a confirmation email.`);
        } else {
          showMessage('success', `Submitted. Queue reference #${data.submissionId}. We sent a confirmation email and the listing is pending review.`);
        }
        form.reset();
      } catch (error) {
        showMessage('error', error.message || 'Submission failed');
      } finally {
        submitButton.disabled = false;
      }
    });
  </script>
</body>
</html>
