<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= agent.name %> — AgentX Registry</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/browse.css">
  <style>
    .agent-detail { max-width: 900px; margin: 2rem auto; padding: 0 1rem; }
    .agent-header { background: #f5f5f5; padding: 2rem; border-radius: 8px; margin-bottom: 2rem; }
    .agent-title { font-size: 2.5rem; margin: 0 0 0.5rem 0; }
    .agent-meta { display: flex; gap: 1rem; margin: 1rem 0; flex-wrap: wrap; }
    .badge { display: inline-block; padding: 0.4rem 0.8rem; border-radius: 4px; font-size: 0.85rem; font-weight: bold; }
    .badge-category { background: #007bff; color: white; }
    .badge-status { background: #28a745; color: white; }
    .section { margin: 2rem 0; }
    .section h2 { border-bottom: 2px solid #007bff; padding-bottom: 0.5rem; }
    .stat-row { display: flex; justify-content: space-between; padding: 1rem 0; border-bottom: 1px solid #eee; }
    .stat-label { font-weight: bold; }
    .capabilities { display: flex; gap: 0.5rem; flex-wrap: wrap; margin-top: 1rem; }
    .capability-tag { background: #e8e8e8; padding: 0.3rem 0.8rem; border-radius: 4px; font-size: 0.9rem; }
    .uptime-trend { display: flex; gap: 3px; margin-top: 1rem; flex-wrap: wrap; }
    .uptime-bar { width: 20px; height: 40px; border-radius: 3px; background: #d3d3d3; }
    .uptime-bar.high { background: #28a745; }
    .uptime-bar.medium { background: #ffc107; }
    .uptime-bar.low { background: #dc3545; }
  </style>
</head>
<body>
  <nav class="navbar">
    <a href="/browse" class="nav-link">← Back to Registry</a>
    <a href="/" class="nav-link">Home</a>
  </nav>

  <div class="agent-detail">
    <div class="agent-header">
      <h1 class="agent-title"><%= agent.name %></h1>
      <p><%= agent.description %></p>
      <div class="agent-meta">
        <span class="badge badge-category"><%= agent.category || 'general' %></span>
        <span class="badge badge-status"><%= agent.status || 'active' %></span>
        <span class="badge"><%= agent.pricing || 'free' %></span>
      </div>
    </div>

    <div class="section">
      <h2>Performance</h2>
      <div class="stat-row">
        <span class="stat-label">7-Day Uptime</span>
        <span><%= uptime7d %>%</span>
      </div>
      <div class="uptime-trend">
        <% uptimeTrend.forEach(point => {
          const pct = point.uptime_pct;
          const cls = pct >= 95 ? 'high' : pct >= 80 ? 'medium' : 'low';
        %>
          <div class="uptime-bar <%= cls %>" title="<%= new Date(point.measured_at).toLocaleDateString() %>: <%= pct.toFixed(1) %>%"></div>
        <% }); %>
      </div>
    </div>

    <% if (agent.capabilities) { %>
    <div class="section">
      <h2>Capabilities</h2>
      <div class="capabilities">
        <% JSON.parse(agent.capabilities).forEach(cap => { %>
          <span class="capability-tag"><%= cap.replace(/-/g, ' ') %></span>
        <% }); %>
      </div>
    </div>
    <% } %>

    <div class="section">
      <h2>Contact</h2>
      <% if (agent.website) { %>
      <div class="stat-row">
        <span class="stat-label">Website</span>
        <span><a href="<%= agent.website %>" target="_blank"><%= agent.website %></a></span>
      </div>
      <% } %>
      <% if (agent.contact_email) { %>
      <div class="stat-row">
        <span class="stat-label">Email</span>
        <span><a href="mailto:<%= agent.contact_email %>"><%= agent.contact_email %></a></span>
      </div>
      <% } %>
    </div>
  </div>
</body>
</html>
