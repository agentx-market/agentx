<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= agent.name %> — <%= agent.description || 'AI Agent' %> | AgentX Registry</title>
  <meta name="description" content="<%= (agent.description || '').substring(0, 160) %>">
  <link rel="canonical" href="https://agentx.market/agents/<%= agent.slug %>">
  
  <!-- Open Graph Tags -->
  <meta property="og:type" content="website">
  <meta property="og:url" content="https://agentx.market/agents/<%= agent.slug %>">
  <meta property="og:title" content="<%= agent.name %> — <%= agent.description || 'AI Agent' %>">
  <meta property="og:description" content="<%= (agent.description || '').substring(0, 160) %>">
  <meta property="og:site_name" content="AgentX Registry">
  
  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="<%= agent.name %>">
  <meta name="twitter:description" content="<%= (agent.description || '').substring(0, 160) %>">
  
  <!-- JSON-LD SoftwareApplication Schema -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "<%= agent.name %>",
    "description": "<%= agent.description || '' %>",
    "applicationCategory": "AIApplication",
    "operatingSystem": "Cloud",
    "offers": {
      "@type": "Offer",
      "price": "<%= agent.pricing || '0' %>",
      "priceCurrency": "USD"
    },
    "author": {
      "@type": "Organization",
      "name": "AgentX"
    }<% if (agent.rating && agent.rating > 0) { %>,
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": <%= agent.rating.toFixed(1) %>,
      "ratingCount": <%= agent.review_count || 1 %>
    }<% } %>
  }
  </script>
  
  <style>
    body { background: #0a0a1a; color: #e0e0ff; }
    .agent-detail { max-width: 900px; margin: 2rem auto; padding: 0 1rem; }
    .agent-header { background: #1a1a2e; border: 1px solid #2a2a4a; border-radius: 12px; padding: 2rem; margin-bottom: 2rem; }
    .agent-title { font-size: 2.5rem; margin: 0 0 0.5rem 0; color: #e0e0ff; }
    .agent-meta { display: flex; gap: 1rem; margin: 1rem 0; flex-wrap: wrap; }
    .badge { display: inline-block; padding: 0.4rem 0.8rem; border-radius: 4px; font-size: 0.85rem; font-weight: bold; }
    .badge-pricing { background: #6c5ce7; color: white; }
    .badge-healthy { background: #4ade80; color: white; }
    .badge-unhealthy { background: #ef4444; color: white; }
    .section { margin: 2rem 0; }
    .section h2 { color: #e0e0ff; border-bottom: 2px solid #6c5ce7; padding-bottom: 0.5rem; }
    .stat-row { display: flex; justify-content: space-between; padding: 1rem 0; border-bottom: 1px solid #2a2a4a; }
    .stat-label { font-weight: bold; color: #a0a0c0; }
    .capabilities { display: flex; gap: 0.5rem; flex-wrap: wrap; margin-top: 1rem; }
    .capability-tag { background: #2a2a4a; color: #e0e0ff; padding: 0.3rem 0.8rem; border-radius: 4px; font-size: 0.9rem; }
    .uptime-trend { display: flex; gap: 3px; margin-top: 1rem; flex-wrap: wrap; }
    .uptime-bar { width: 20px; height: 40px; border-radius: 3px; background: #2a2a4a; }
    .uptime-bar.high { background: #4ade80; }
    .uptime-bar.medium { background: #6c5ce7; }
    .uptime-bar.low { background: #ef4444; }
    /* Reviews */
    .reviews-section { margin-top: 3rem; }
    .reviews-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; }
    .rating-summary { display: flex; align-items: center; gap: 1rem; }
    .big-rating { font-size: 3rem; font-weight: bold; color: #6c5ce7; }
    .rating-count { color: #a0a0c0; font-size: 1rem; }
    .star-rating { display: flex; gap: 0.2rem; }
    .star { color: #4a4a6a; font-size: 1.2rem; }
    .star.filled { color: #fbbf24; }
    .review-card { background: #1a1a2e; border: 1px solid #2a2a4a; border-radius: 8px; padding: 1.5rem; margin-bottom: 1rem; }
    .review-header { display: flex; justify-content: space-between; margin-bottom: 0.5rem; }
    .reviewer-name { font-weight: bold; color: #e0e0ff; }
    .review-date { color: #a0a0c0; font-size: 0.85rem; }
    .review-text { color: #c0c0d0; line-height: 1.6; }
    /* Similar Agents */
    .similar-agents-section { margin-top: 3rem; }
    .similar-agents-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 1rem; }
    .similar-agent-card { background: #1a1a2e; border: 1px solid #2a2a4a; border-radius: 8px; padding: 1rem; transition: transform 0.2s, border-color 0.2s; }
    .similar-agent-card:hover { transform: translateY(-2px); border-color: #6c5ce7; }
    .similar-agent-name { font-weight: bold; color: #e0e0ff; margin-bottom: 0.5rem; }
    .similar-agent-desc { color: #a0a0c0; font-size: 0.9rem; margin-bottom: 0.8rem; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
    .similar-agent-meta { display: flex; gap: 0.8rem; font-size: 0.85rem; color: #8080a0; }
    .similar-agent-rating { color: #fbbf24; }
    .review-form { background: #1a1a2e; border: 1px solid #2a2a4a; border-radius: 8px; padding: 1.5rem; margin-top: 2rem; }
    .form-group { margin-bottom: 1rem; }
    .form-label { display: block; margin-bottom: 0.5rem; color: #e0e0ff; font-weight: 500; }
    .form-input, .form-textarea { width: 100%; padding: 0.75rem; border: 1px solid #2a2a4a; border-radius: 6px; background: #0a0a1a; color: #e0e0ff; font-size: 1rem; }
    .form-textarea { min-height: 120px; resize: vertical; }
    .star-input { display: flex; gap: 0.5rem; }
    .star-btn { background: none; border: none; font-size: 2rem; cursor: pointer; color: #4a4a6a; transition: color 0.2s; }
    .star-btn:hover, .star-btn.active { color: #fbbf24; }
    .error-msg { color: #ef4444; margin-top: 0.5rem; font-size: 0.9rem; }
    .success-msg { color: #4ade80; margin-top: 0.5rem; font-size: 0.9rem; }
    /* Similar Agents */
    .similar-agents-section { margin-top: 3rem; }
    .similar-agents-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 1rem; }
    .similar-agent-card { background: #1a1a2e; border: 1px solid #2a2a4a; border-radius: 8px; padding: 1rem; transition: transform 0.2s, border-color 0.2s; text-decoration: none; display: block; }
    .similar-agent-card:hover { transform: translateY(-2px); border-color: #6c5ce7; }
    .similar-agent-name { font-weight: bold; color: #e0e0ff; margin-bottom: 0.5rem; }
    .similar-agent-desc { color: #a0a0c0; font-size: 0.9rem; margin-bottom: 0.8rem; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
    .similar-agent-meta { display: flex; gap: 0.8rem; font-size: 0.85rem; color: #8080a0; }
    .similar-agent-rating { color: #fbbf24; }
    /* README Content */
    .readme-content { color: #c0c0d0; line-height: 1.8; }
    .readme-content h3 { color: #e0e0ff; margin-top: 1.5rem; }
    .readme-content p { margin-bottom: 1rem; }
    /* Use Cases */
    .use-cases { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.5rem; }
    .use-case-card { background: #1a1a2e; border: 1px solid #2a2a4a; border-radius: 8px; padding: 1.5rem; }
    .use-case-card h3 { color: #e0e0ff; margin: 0 0 0.8rem 0; font-size: 1.2rem; }
    .use-case-card p { color: #a0a0c0; margin: 0; line-height: 1.6; }
    /* Integration Examples */
    .integration-examples { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1.5rem; }
    .integration-card { background: #1a1a2e; border: 1px solid #2a2a4a; border-radius: 8px; padding: 1.5rem; }
    .integration-card h3 { color: #e0e0ff; margin: 0 0 1rem 0; font-size: 1.1rem; }
    .integration-card pre { background: #0a0a1a; border: 1px solid #2a2a4a; border-radius: 6px; padding: 1rem; overflow-x: auto; }
    .integration-code { font-family: 'JetBrains Mono', monospace; font-size: 0.85rem; color: #a0d0a0; }
  </style>
</head>
<body>
  <nav class="navbar">
    <div class="container">
      <a href="/" class="nav-logo"><div class="logo-icon">X</div>AgentX</a>
      <ul class="nav-links">
        <li><a href="/features">Features</a></li>
        <li><a href="/pricing">Pricing</a></li>
        <li><a href="/browse">Browse</a></li>
        <li><a href="/about">About</a></li>
        <li><a href="/contact">Contact</a></li>
        <li><a href="/login">Login</a></li>
        <li class="nav-cta"><a href="/pricing" class="btn btn-primary">Get Started</a></li>
      </ul>
    </div>
  </nav>

  <div class="agent-detail">
    <div class="agent-header">
      <h1 class="agent-title"><%= agent.name %></h1>
      <p><%= agent.description %></p>
      <div class="agent-meta">
        <span class="badge badge-pricing"><%= agent.pricing || 'Free' %></span>
        <% if (agent.health_check_passed_at && Date.now() - agent.health_check_passed_at < 300000) { %>
          <span class="badge badge-healthy">Healthy</span>
        <% } else { %>
          <span class="badge badge-unhealthy">Unhealthy</span>
        <% } %>
      </div>
    </div>

    <div class="section">
      <h2>Performance</h2>
      <div class="stat-row">
        <span class="stat-label">7-Day Uptime</span>
        <span><%= uptime7d %></span>
      </div>
      <div class="uptime-trend">
        <% uptimeTrend.forEach(point => {
          const pct = point.uptime_pct;
          const cls = pct >= 95 ? 'high' : pct >= 80 ? 'medium' : 'low';
        %>
          <div class="uptime-bar <%= cls %>" title="<%= new Date(point.measured_at).toLocaleDateString() %>: <%= pct.toFixed(1) %>%"></div>
        <% }); %>
      </div>
    </div>

    <% if (agent.capabilities) { %>
    <div class="section">
      <h2>Capabilities</h2>
      <div class="capabilities">
        <% JSON.parse(agent.capabilities).forEach(cap => { %>
          <span class="capability-tag"><%= cap.replace(/-/g, ' ') %></span>
        <% }); %>
      </div>
    </div>
    <% } %>

    <% if (agent.description) { %>
    <div class="section">
      <h2>About <%= agent.name %></h2>
      <div class="readme-content" style="color: #c0c0d0; line-height: 1.8;">
        <%= agent.description.replace(/\n/g, '<br>') %>
      </div>
    </div>
    <% } %>

    <div class="section">
      <h2>Use Cases</h2>
      <div class="use-cases">
        <div class="use-case-card">
          <h3>🚀 Rapid Development</h3>
          <p>Integrate powerful AI capabilities into your applications without building from scratch. Save weeks of development time.</p>
        </div>
        <div class="use-case-card">
          <h3>📊 Data Processing</h3>
          <p>Automate complex data analysis, transformation, and reporting tasks with specialized AI agents.</p>
        </div>
        <div class="use-case-card">
          <h3>🤖 Workflow Automation</h3>
          <p>Streamline repetitive tasks and create intelligent automation pipelines that learn and adapt.</p>
        </div>
        <div class="use-case-card">
          <h3>🎯 Specialized Tasks</h3>
          <p>Leverage domain-specific AI models for coding, content creation, customer support, and more.</p>
        </div>
      </div>
    </div>

    <div class="section">
      <h2>Integration Examples</h2>
      <div class="integration-examples">
        <div class="integration-card">
          <h3>Node.js SDK</h3>
          <pre><code>const AgentX = require('agentx-sdk');
const agent = new AgentX('<%= agent.name %>');

// Make a request
const result = await agent.process({
  input: 'Your data here',
  options: { timeout: 30000 }
});

console.log(result.output);</code></pre>
        </div>
        <div class="integration-card">
          <h3>REST API</h3>
          <pre><code>curl -X POST https://api.agentx.market/agents/<%= agent.slug %>/process \
  -H "Content-Type: application/json" \
  -H "Authorization: Bearer YOUR_API_KEY" \
  -d '{"input": "Your request"}'</code></pre>
        </div>
        <div class="integration-card">
          <h3>Python Client</h3>
          <pre><code>import requests

response = requests.post(
    'https://api.agentx.market/agents/<%= agent.slug %>/process',
    headers={'Authorization': 'Bearer YOUR_API_KEY'},
    json={'input': 'Your request'}
)

print(response.json()['output'])</code></pre>
        </div>
      </div>
    </div>

    <% if (similarAgents.length > 0) { %>
    <div class="section similar-agents-section">
      <h2>Similar Agents</h2>
      <div class="similar-agents-grid">
        <% similarAgents.forEach(similar => { %>
          <a href="/agents/<%= similar.slug %>" class="similar-agent-card">
            <div class="similar-agent-name"><%= similar.name %></div>
            <div class="similar-agent-desc"><%= similar.description || 'No description available' %></div>
            <div class="similar-agent-meta">
              <% if (similar.rating) { %>
                <span class="similar-agent-rating">★ <%= similar.rating.toFixed(1) %></span>
              <% } %>
              <% if (similar.uptime_percent) { %>
                <span><%= Math.round(similar.uptime_percent * 100) / 100 %>% uptime</span>
              <% } %>
            </div>
          </a>
        <% }); %>
      </div>
    </div>
    <% } %>

    <% if (agent.rating || agent.review_count > 0) { %>
    <div class="section reviews-section">
      <div class="reviews-header">
        <h2>Reviews</h2>
        <div class="rating-summary">
          <div class="big-rating"><%= (agent.rating || 0).toFixed(1) %></div>
          <div>
            <div class="star-rating">
              <% for (let i = 1; i <= 5; i++) { %>
                <span class="star <%= i <= Math.round(agent.rating || 0) ? 'filled' : '' %>">★</span>
              <% } %>
            </div>
            <div class="rating-count"><%= agent.review_count %> <%= agent.review_count === 1 ? 'review' : 'reviews' %></div>
          </div>
        </div>
      </div>
      
      <% reviews.forEach(review => { %>
        <div class="review-card">
          <div class="review-header">
            <span class="reviewer-name"><%= review.user_name || 'Anonymous' %></span>
            <span class="review-date"><%= new Date(review.created_at).toLocaleDateString() %></span>
          </div>
          <div class="star-rating" style="margin-bottom: 0.5rem;">
            <% for (let i = 1; i <= 5; i++) { %>
              <span class="star <%= i <= review.rating ? 'filled' : '' %>">★</span>
            <% } %>
          </div>
          <% if (review.review_text) { %>
            <p class="review-text"><%= review.review_text %></p>
          <% } %>
        </div>
      <% }); %>
    </div>
    <% } %>

    <% if (isLoggedIn) { %>
    <div class="section reviews-section">
      <h2>Leave a Review</h2>
      <div class="review-form">
        <form id="review-form">
          <div class="form-group">
            <label class="form-label">Rating</label>
            <div class="star-input" id="star-input">
              <% for (let i = 1; i <= 5; i++) { %>
                <button type="button" class="star-btn" data-rating="<%= i %>">★</button>
              <% } %>
            </div>
            <input type="hidden" id="rating" name="rating" value="">
          </div>
          <div class="form-group">
            <label class="form-label">Review (optional)</label>
            <textarea class="form-textarea" id="review_text" name="review_text" placeholder="Share your experience with this agent..."></textarea>
          </div>
          <button type="submit" class="btn btn-primary">Submit Review</button>
          <div id="form-message"></div>
        </form>
      </div>
    </div>
    <% } else { %>
    <div class="section reviews-section">
      <p style="color: #a0a0c0; text-align: center;">
        <a href="/login" style="color: #6c5ce7;">Log in</a> to leave a review
      </p>
    </div>
    <% } %>
  </div>

  <script>
    // Star rating input
    const starBtns = document.querySelectorAll('#star-input .star-btn');
    const ratingInput = document.getElementById('rating');
    let selectedRating = 0;
    
    starBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        selectedRating = parseInt(btn.dataset.rating);
        ratingInput.value = selectedRating;
        starBtns.forEach((b, i) => {
          b.classList.toggle('active', i < selectedRating);
        });
      });
    });
    
    // Form submission
    document.getElementById('review-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      const messageDiv = document.getElementById('form-message');
      
      if (!selectedRating) {
        messageDiv.innerHTML = '<div class="error-msg">Please select a rating</div>';
        return;
      }
      
      const formData = {
        agent_id: <%= agent.id %>,
        rating: selectedRating,
        review_text: document.getElementById('review_text').value
      };
      
      try {
        const res = await fetch('/api/reviews', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(formData)
        });
        
        const data = await res.json();
        
        if (res.ok) {
          messageDiv.innerHTML = '<div class="success-msg">Review submitted successfully!</div>';
          document.getElementById('review-form').reset();
          selectedRating = 0;
          starBtns.forEach(b => b.classList.remove('active'));
          // Reload page to show new review
          setTimeout(() => window.location.reload(), 1500);
        } else {
          messageDiv.innerHTML = `<div class="error-msg">${data.error || 'Failed to submit review'}</div>`;
        }
      } catch (err) {
        messageDiv.innerHTML = '<div class="error-msg">Failed to submit review. Please try again.</div>';
      }
    });
  </script>
</body>
</html>